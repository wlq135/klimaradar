# App
BASE_URL=http://localhost:8000
APP_NAME=KlimaRadar
DEBUG=false

# Database (SQLite for MVP; switch to PostgreSQL later)
DATABASE_URL=sqlite+aiosqlite:///./klimaradar.db

# Email (Brevo API > SMTP > SendGrid; leave all empty to print to console)
SENDGRID_API_KEY=
FROM_EMAIL=alerts@klima-radar.com

# Brevo v3 transactional email API key — useful when SMTP is not yet activated.
BREVO_API_KEY=

# SMTP relay (e.g. Brevo, Mailgun).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Admin API key for protected endpoints (e.g. /api/admin/scrape). Must be set in production.
ADMIN_API_KEY=

# Demo data/spider. Keep false on the public site.
ENABLE_DEMO=false

# Affiliate tags (optional; used by affiliate.py to tag outbound links)
AMAZON_DE_AFFILIATE_TAG=
AMAZON_FR_AFFILIATE_TAG=
AMAZON_IT_AFFILIATE_TAG=
AMAZON_ES_AFFILIATE_TAG=
AMAZON_NL_AFFILIATE_TAG=
AMAZON_BE_AFFILIATE_TAG=
MEDIAMARKT_DE_AFFILIATE_TAG=
BOULANGER_FR_AFFILIATE_TAG=
DARTY_FR_AFFILIATE_TAG=

# Analytics (optional). Set PLAUSIBLE_DOMAIN to enable Plausible Analytics.
PLAUSIBLE_DOMAIN=klima-radar.com
# Use the exact script URL shown in your Plausible site settings (may include extensions).
PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js

# Google Search Console verification meta tag content (optional).
GOOGLE_SITE_VERIFICATION=
PLAYWRIGHT_PROXY_USERNAME=
PLAYWRIGHT_PROXY_PASSWORD=
# Comma-separated list of spider names that should use the proxy. Leave empty to apply to all.
# Example: PLAYWRIGHT_PROXY_RETAILERS="Boulanger France,Darty France"
PLAYWRIGHT_PROXY_RETAILERS=

# Paddle Billing (legacy; kept for existing webhooks).
PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID=

# Lemon Squeezy Billing (new default checkout).
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_VARIANT_ID=

# Scraping
SCRAPER_INTERVAL_MINUTES=10
REQUEST_TIMEOUT_SECONDS=30
USER_AGENT=Mozilla/5.0 (compatible; KlimaRadar/1.0; +https://klima-radar.com)
