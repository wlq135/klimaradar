# App
BASE_URL=http://localhost:8000
APP_NAME=KlimaRadar
DEBUG=false

# Database (SQLite for MVP; switch to PostgreSQL later)
DATABASE_URL=sqlite+aiosqlite:///./klimaradar.db

# Email (Brevo API > SMTP > SendGrid; leave all empty to print to console)
SENDGRID_API_KEY=
FROM_EMAIL=alerts@klima-radar.com

# Brevo v3 transactional email API key — useful when SMTP is not yet activated.
BREVO_API_KEY=

# SMTP relay (e.g. Brevo, Mailgun).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Admin API key for protected endpoints (e.g. /api/admin/scrape). Must be set in production.
ADMIN_API_KEY=

# Demo data/spider. Keep false on the public site.
ENABLE_DEMO=false

# Affiliate tags (optional; used by affiliate.py to tag outbound links)
AMAZON_DE_AFFILIATE_TAG=klrmrd-21
AMAZON_FR_AFFILIATE_TAG=klrmrd-21
MEDIAMARKT_DE_AFFILIATE_TAG=klrmrd
BOULANGER_FR_AFFILIATE_TAG=klrmrd
DARTY_FR_AFFILIATE_TAG=klrmrd

# Playwright proxy (optional; required for some heavily protected sites such as Boulanger FR)
# Example: http://proxy.example.com:8080 or http://lum-customer-xyz-zone-residential:password@proxy.zenrows.com:1337
PLAYWRIGHT_PROXY_SERVER=
PLAYWRIGHT_PROXY_USERNAME=
PLAYWRIGHT_PROXY_PASSWORD=
# Comma-separated list of spider names that should use the proxy. Leave empty to apply to all.
# Example: PLAYWRIGHT_PROXY_RETAILERS="Boulanger France,Darty France"
PLAYWRIGHT_PROXY_RETAILERS=

# Scraping
SCRAPER_INTERVAL_MINUTES=10
REQUEST_TIMEOUT_SECONDS=30
USER_AGENT=Mozilla/5.0 (compatible; KlimaRadar/1.0; +https://klima-radar.com)
